# ==============================================================================
# Advanced B.Tech Course-book RAG Assistant - Environment Configuration
# ==============================================================================
# Instructions: Copy this file to a new file named '.env' and fill in your API keys.
# DO NOT commit your actual '.env' file containing active keys to git!
# ==============================================================================

# LLM Provider Keys (You only need ONE of these keys to run the pipeline)
# ------------------------------------------------------------------------------

# 1. Google Gemini API Key (Recommended Cloud Tier - gemini-2.5-flash)
# Get a key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# 2. Groq Cloud API Key (Generous Free Tier - llama-3.1-8b-instant)
# Get a key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# 3. OpenAI API Key (Standard Fallback - gpt-4o-mini)
# Get a key from: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# Optional: LangChain Tracing (LangSmith Monitoring)
# ------------------------------------------------------------------------------
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=http://localhost:8000
